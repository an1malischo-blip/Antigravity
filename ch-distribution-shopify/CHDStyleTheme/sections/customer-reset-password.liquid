{% comment %}
  CH Distribution — Passwort zurücksetzen
{% endcomment %}

<div class="customer-auth">
  <div class="customer-auth__card">
    <h1 class="customer-auth__title">{{ 'customers.reset_password.title' | t }}</h1>

    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}
        <div class="customer-auth__error">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="customer-auth__field">
        <label for="reset-password">{{ 'customers.reset_password.password' | t }}</label>
        <input
          type="password"
          name="customer[password]"
          id="reset-password"
          autocomplete="new-password"
          required
        >
      </div>

      <div class="customer-auth__field">
        <label for="reset-password-confirm">{{ 'customers.reset_password.password_confirm' | t }}</label>
        <input
          type="password"
          name="customer[password_confirmation]"
          id="reset-password-confirm"
          autocomplete="new-password"
          required
        >
      </div>

      <button type="submit" class="customer-auth__submit">
        {{ 'customers.reset_password.submit' | t }}
      </button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "t:customers.reset_password.title",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

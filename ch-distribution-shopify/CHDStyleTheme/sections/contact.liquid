<div class="contact full-width">
  <div class="contact__inner">
    <div class="contact__info">
      {% if section.settings.eyebrow != blank %}
        <span class="contact__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="contact__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="contact__description">{{ section.settings.description }}</p>
      {% endif %}

      <div class="contact__details">
        {% if section.settings.email != blank %}
          <a href="mailto:{{ section.settings.email }}" class="contact__detail">
            <span class="contact__detail-label">{{ 'sections.contact.email' | t }}</span>
            <span class="contact__detail-value">{{ section.settings.email }}</span>
          </a>
        {% endif %}

        {% if section.settings.phone != blank %}
          <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact__detail">
            <span class="contact__detail-label">{{ 'sections.contact.phone' | t }}</span>
            <span class="contact__detail-value">{{ section.settings.phone }}</span>
          </a>
        {% endif %}

        {% if section.settings.address != blank %}
          <div class="contact__detail">
            <span class="contact__detail-label">{{ 'sections.contact.address' | t }}</span>
            <span class="contact__detail-value">{{ section.settings.address }}</span>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="contact__form-wrapper">
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="contact__success">{{ 'sections.contact.success' | t }}</p>
        {% endif %}

        {% if form.errors %}
          <div class="contact__errors">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="contact__field">
          <label for="contact-name" class="contact__label">{{ 'sections.contact.form_name' | t }}</label>
          <input type="text" id="contact-name" name="contact[name]" required class="contact__input">
        </div>

        <div class="contact__field">
          <label for="contact-email" class="contact__label">{{ 'sections.contact.form_email' | t }}</label>
          <input type="email" id="contact-email" name="contact[email]" required class="contact__input">
        </div>

        <div class="contact__field">
          <label for="contact-company" class="contact__label">{{ 'sections.contact.form_company' | t }}</label>
          <input type="text" id="contact-company" name="contact[company]" class="contact__input">
        </div>

        <div class="contact__field">
          <label for="contact-message" class="contact__label">{{ 'sections.contact.form_message' | t }}</label>
          <textarea id="contact-message" name="contact[body]" rows="5" required class="contact__textarea"></textarea>
        </div>

        <button type="submit" class="contact__submit">
          {{ 'sections.contact.form_submit' | t }}
        </button>
      {% endform %}
    </div>
  </div>
</div>

{% stylesheet %}
  .contact {
    background-color: var(--color-background-secondary);
    padding: 4rem var(--page-margin);
  }

  .contact__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  .contact__eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .contact__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-foreground);
    margin-bottom: 1rem;
  }

  .contact__description {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-foreground);
    opacity: 0.65;
    margin-bottom: 2rem;
  }

  .contact__details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__detail {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-decoration: none;
    color: var(--color-foreground);
    transition: color 0.2s ease;
  }

  a.contact__detail:hover {
    color: var(--color-accent);
  }

  .contact__detail-label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.45;
  }

  .contact__detail-value {
    font-size: 0.95rem;
    font-weight: 500;
  }

  .contact__form-wrapper {
    background-color: var(--color-background);
    border-radius: var(--style-border-radius-cards);
    padding: 2rem;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .contact__success {
    background-color: #e8f5e9;
    color: #2e7d32;
    padding: 1rem;
    border-radius: var(--style-border-radius-inputs);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .contact__errors {
    background-color: #fce4ec;
    color: #c62828;
    padding: 1rem;
    border-radius: var(--style-border-radius-inputs);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .contact__field {
    margin-bottom: 1.25rem;
  }

  .contact__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.6;
    margin-bottom: 0.4rem;
  }

  .contact__input,
  .contact__textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 0.9rem;
    font-family: var(--font-primary--family);
    color: var(--color-foreground);
    background-color: var(--color-background-secondary);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: var(--style-border-radius-inputs);
    transition: border-color 0.2s ease;
  }

  .contact__input:focus,
  .contact__textarea:focus {
    outline: none;
    border-color: var(--color-accent);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__submit {
    display: inline-block;
    width: 100%;
    padding: 0.9rem 2.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-primary--family);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-text);
    background-color: var(--color-accent);
    border: 2px solid var(--color-accent);
    border-radius: var(--style-border-radius-buttons);
    cursor: pointer;
    transition: all 0.25s ease;
  }

  .contact__submit:hover {
    background-color: #0256cc;
    border-color: #0256cc;
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(3, 75, 174, 0.4);
  }

  @media (min-width: 768px) {
    .contact {
      padding: 6rem var(--page-margin);
    }

    .contact__inner {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .contact__heading {
      font-size: 2.75rem;
    }

    .contact__form-wrapper {
      padding: 2.5rem;
    }
  }

  @media (min-width: 1024px) {
    .contact__heading {
      font-size: 3.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.contact.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.contact.schema.eyebrow",
      "default": "Get in touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact.schema.heading",
      "default": "Let's work together"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.contact.schema.description",
      "default": "Interested in becoming a distribution partner? Get in touch with us and we'll get back to you within 24 hours."
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:sections.contact.schema.email",
      "default": "info@chdistribution.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "t:sections.contact.schema.phone",
      "default": "+49 160 4430444"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "t:sections.contact.schema.address",
      "default": "Langwedeler Straße 82, 28307 Bremen"
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact.name"
    }
  ]
}
{% endschema %}

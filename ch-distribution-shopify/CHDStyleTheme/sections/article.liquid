{% comment %}
  CH Distribution — Artikel-Seite (Blog Post)
{% endcomment %}

<article class="article-page">
  {%- if article.image -%}
    <div class="article-page__hero">
      {{ article.image | image_url: width: 1600, height: 700, crop: 'center' | image_tag: loading: 'eager', class: 'article-page__hero-img' }}
    </div>
  {%- endif -%}

  <div class="article-page__container">
    <header class="article-page__header">
      {%- if article.tags.size > 0 -%}
        <div class="article-page__tags">
          {%- for tag in article.tags -%}
            <span class="article-page__tag">{{ tag }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <h1 class="article-page__title">{{ article.title }}</h1>

      <div class="article-page__meta">
        <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
          {{ article.published_at | date: '%d. %B %Y' }}
        </time>
        <span class="article-page__meta-sep">&middot;</span>
        <span>{{ article.author }}</span>
      </div>
    </header>

    <div class="article-page__content rte">
      {{ article.content }}
    </div>

    {%- if blog -%}
      <div class="article-page__back">
        <a href="{{ blog.url }}" class="article-page__back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          {{ 'blog.back_to_blog' | t }}
        </a>
      </div>
    {%- endif -%}

    {%- if blog.comments_enabled? -%}
      <section class="article-comments" id="comments">
        <h2 class="article-comments__title">
          {{ 'blog.article_comments' | t }}
          {%- if article.comments_count > 0 -%}
            <span class="article-comments__count">({{ article.comments_count }})</span>
          {%- endif -%}
        </h2>

        {%- paginate article.comments by 10 -%}
          {%- if article.comments_count > 0 -%}
            <div class="article-comments__list">
              {%- for comment in article.comments -%}
                <div class="article-comment">
                  <div class="article-comment__avatar">
                    {{ comment.author | slice: 0 | upcase }}
                  </div>
                  <div class="article-comment__body">
                    <div class="article-comment__header">
                      <span class="article-comment__author">{{ comment.author }}</span>
                      <time class="article-comment__date" datetime="{{ comment.created_at | date: '%Y-%m-%d' }}">
                        {{ comment.created_at | date: '%d. %B %Y' }}
                      </time>
                    </div>
                    <div class="article-comment__text">{{ comment.content }}</div>
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- if paginate.pages > 1 -%}
              <nav class="article-comments__pagination">
                {{ paginate | default_pagination: anchor: 'comments' }}
              </nav>
            {%- endif -%}
          {%- endif -%}
        {%- endpaginate -%}

        {%- form 'new_comment', article -%}
          <div class="article-comment-form">
            <h3 class="article-comment-form__title">{{ 'blog.comment_form_title' | t }}</h3>

            {%- if form.errors -%}
              <div class="article-comment-form__errors">
                {{ form.errors | default_errors }}
              </div>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <div class="article-comment-form__success">
                {{ 'blog.comment_success' | t }}
              </div>
            {%- endif -%}

            <div class="article-comment-form__row">
              <div class="article-comment-form__field">
                <label for="comment-author">{{ 'blog.comment_form_name' | t }}</label>
                <input type="text" name="comment[author]" id="comment-author" value="{{ form.author }}" required>
              </div>
              <div class="article-comment-form__field">
                <label for="comment-email">{{ 'blog.comment_form_email' | t }}</label>
                <input type="email" name="comment[email]" id="comment-email" value="{{ form.email }}" required>
              </div>
            </div>

            <div class="article-comment-form__field">
              <label for="comment-body">{{ 'blog.comment_form_body' | t }}</label>
              <textarea name="comment[body]" id="comment-body" rows="5" required>{{ form.body }}</textarea>
            </div>

            <button type="submit" class="article-comment-form__submit">
              {{ 'blog.comment_form_submit' | t }}
            </button>
          </div>
        {%- endform -%}
      </section>
    {%- endif -%}
  </div>
</article>

{% stylesheet %}
.article-page {
  padding-bottom: 3rem;
}

/* Hero Image */
.article-page__hero {
  aspect-ratio: 16 / 7;
  overflow: hidden;
  margin-bottom: 2rem;
  border-radius: var(--style-border-radius-cards);
}

.article-page__hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* Container */
.article-page__container {
  max-width: 48rem;
  margin: 0 auto;
}

/* Header */
.article-page__header {
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

.article-page__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.article-page__tag {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-accent);
  background: rgba(3, 75, 174, 0.08);
  padding: 0.2rem 0.6rem;
  border-radius: 3px;
}

.article-page__title {
  font-family: var(--font-heading--family);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1.2;
  color: var(--color-foreground);
  margin: 0 0 0.75rem;
}

@media (min-width: 768px) {
  .article-page__title {
    font-size: 2.6rem;
  }
}

.article-page__meta {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.85rem;
  color: #9ca3af;
}

.article-page__meta-sep {
  color: #d1d5db;
}

/* Content / RTE */
.article-page__content.rte {
  font-size: 1rem;
  line-height: 1.8;
  color: var(--color-foreground);
}

.article-page__content.rte h2 {
  font-family: var(--font-heading--family);
  font-size: 1.5rem;
  font-weight: 700;
  margin: 2rem 0 0.75rem;
  color: var(--color-foreground);
}

.article-page__content.rte h3 {
  font-family: var(--font-heading--family);
  font-size: 1.25rem;
  font-weight: 700;
  margin: 1.5rem 0 0.5rem;
}

.article-page__content.rte p {
  margin: 0 0 1.25rem;
}

.article-page__content.rte img {
  border-radius: var(--style-border-radius-cards);
  margin: 1.5rem 0;
}

.article-page__content.rte ul,
.article-page__content.rte ol {
  padding-left: 1.5rem;
  margin: 0 0 1.25rem;
}

.article-page__content.rte li {
  margin-bottom: 0.4rem;
}

.article-page__content.rte a {
  color: var(--color-accent);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.article-page__content.rte blockquote {
  border-left: 3px solid var(--color-accent);
  padding: 0.75rem 1.25rem;
  margin: 1.5rem 0;
  background: rgba(3, 75, 174, 0.04);
  font-style: italic;
  color: #4b5563;
}

.article-page__content.rte table {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-size: 0.9rem;
}

.article-page__content.rte th,
.article-page__content.rte td {
  padding: 0.6rem 0.75rem;
  border: 1px solid #e5e7eb;
  text-align: left;
}

.article-page__content.rte th {
  background: var(--color-background-secondary);
  font-weight: 700;
}

/* Back link */
.article-page__back {
  margin-top: 2rem;
  padding-top: 1.5rem;
  border-top: 1px solid #e5e7eb;
}

.article-page__back-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-accent);
  text-decoration: none;
  transition: gap 0.2s ease;
}

.article-page__back-link:hover {
  gap: 0.6rem;
}

/* Comments */
.article-comments {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 2px solid #e5e7eb;
}

.article-comments__title {
  font-family: var(--font-heading--family);
  font-size: 1.4rem;
  font-weight: 700;
  margin: 0 0 1.5rem;
}

.article-comments__count {
  font-weight: 400;
  color: #9ca3af;
}

.article-comments__list {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  margin-bottom: 2rem;
}

.article-comment {
  display: flex;
  gap: 0.75rem;
}

.article-comment__avatar {
  flex-shrink: 0;
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  background: var(--color-accent);
  color: var(--color-accent-text);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.9rem;
  font-weight: 700;
}

.article-comment__body {
  flex: 1;
  min-width: 0;
}

.article-comment__header {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
  margin-bottom: 0.25rem;
}

.article-comment__author {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-foreground);
}

.article-comment__date {
  font-size: 0.75rem;
  color: #9ca3af;
}

.article-comment__text {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #4b5563;
}

.article-comments__pagination {
  margin-bottom: 2rem;
}

/* Comment Form */
.article-comment-form {
  background: var(--color-background-secondary);
  padding: 1.5rem;
  border-radius: var(--style-border-radius-cards);
}

.article-comment-form__title {
  font-family: var(--font-heading--family);
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0 0 1rem;
}

.article-comment-form__errors {
  background: #fef2f2;
  border: 1px solid #fca5a5;
  border-radius: var(--style-border-radius-inputs);
  padding: 0.75rem 1rem;
  margin-bottom: 1rem;
  font-size: 0.85rem;
  color: #dc2626;
}

.article-comment-form__success {
  background: #f0fdf4;
  border: 1px solid #86efac;
  border-radius: var(--style-border-radius-inputs);
  padding: 0.75rem 1rem;
  margin-bottom: 1rem;
  font-size: 0.85rem;
  color: #16a34a;
}

.article-comment-form__row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  margin-bottom: 1rem;
}

@media (min-width: 600px) {
  .article-comment-form__row {
    grid-template-columns: 1fr 1fr;
  }
}

.article-comment-form__field label {
  display: block;
  font-size: 0.8rem;
  font-weight: 600;
  margin-bottom: 0.3rem;
  color: var(--color-foreground);
}

.article-comment-form__field input,
.article-comment-form__field textarea {
  width: 100%;
  padding: 0.6rem 0.75rem;
  border: 2px solid #d1d5db;
  border-radius: var(--style-border-radius-inputs);
  font-size: 0.85rem;
  font-family: inherit;
  background: var(--color-background);
  color: var(--color-foreground);
  transition: border-color 0.15s ease;
}

.article-comment-form__field input:focus,
.article-comment-form__field textarea:focus {
  outline: none;
  border-color: var(--color-accent);
}

.article-comment-form__field textarea {
  resize: vertical;
}

.article-comment-form__field {
  margin-bottom: 1rem;
}

.article-comment-form__submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.7rem 1.5rem;
  background-color: var(--color-accent);
  color: var(--color-accent-text);
  border: 2px solid var(--color-accent);
  border-radius: var(--style-border-radius-buttons);
  font-size: 0.85rem;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  transition: background-color 0.2s ease;
}

.article-comment-form__submit:hover {
  background-color: #162e78;
  border-color: #162e78;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.article",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

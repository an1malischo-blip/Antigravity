<div class="hero full-width">
  {% if section.settings.background_image %}
    <div class="hero__background">
      {{ section.settings.background_image | image_url: width: 2000 | image_tag: loading: 'eager' }}
    </div>
  {% endif %}

  <div class="hero__overlay"></div>

  <div class="hero__content">
    {% if section.settings.eyebrow != blank %}
      <span class="hero__eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="hero__actions">
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="hero__button hero__button--primary">
          {{ section.settings.button_label }}
        </a>
      {% endif %}

      {% if section.settings.button_secondary_label != blank %}
        <a href="{{ section.settings.button_secondary_link }}" class="hero__button hero__button--secondary">
          {{ section.settings.button_secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    overflow: hidden;
    background-color: #0a1628;
  }

  .hero__background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__background img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(3, 15, 40, 0.65) 0%,
      rgba(3, 75, 174, 0.35) 100%
    );
    z-index: 1;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 4rem var(--page-margin);
    max-width: 52rem;
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 0.4rem 1.25rem;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .hero__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 1.25rem;
  }

  .hero__subheading {
    font-size: 1.05rem;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 2.5rem;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  .hero__button {
    display: inline-block;
    padding: 0.9rem 2.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: var(--style-border-radius-buttons);
    transition: all 0.25s ease;
  }

  .hero__button--primary {
    background-color: var(--color-accent);
    color: var(--color-accent-text);
    border: 2px solid var(--color-accent);
  }

  .hero__button--primary:hover {
    background-color: #0256cc;
    border-color: #0256cc;
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(3, 75, 174, 0.4);
  }

  .hero__button--secondary {
    background-color: transparent;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
  }

  .hero__button--secondary:hover {
    border-color: #fff;
    background-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 85vh;
    }

    .hero__eyebrow {
      font-size: 0.8rem;
      margin-bottom: 2rem;
    }

    .hero__heading {
      font-size: 4rem;
    }

    .hero__subheading {
      font-size: 1.15rem;
    }
  }

  @media (min-width: 1024px) {
    .hero__heading {
      font-size: 4.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.hero.settings.background_image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.hero.settings.eyebrow",
      "default": "B2B Distribution"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero.settings.heading",
      "default": "Premium products for the European market"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.hero.settings.subheading",
      "default": "CH Distribution is your reliable partner for the wholesale of international brand snacks, sweets, and vapes across Europe."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.hero.settings.button_label",
      "default": "View products"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.hero.settings.button_link"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "t:sections.hero.settings.button_secondary_label",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "t:sections.hero.settings.button_secondary_link"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.name"
    }
  ]
}
{% endschema %}

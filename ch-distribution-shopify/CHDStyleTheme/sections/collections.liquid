{% comment %}
  CH Distribution — Alle Kollektionen Übersicht
{% endcomment %}

<div class="collections-page">
  <h1 class="collections-page__title">{{ 'collections.title' | t }}</h1>

  <div class="collections-grid">
    {%- for collection in collections -%}
      <a href="{{ collection.url }}" class="collections-card">
        <div class="collections-card__image-wrap">
          {%- if collection.featured_image -%}
            {{ collection.featured_image | image_url: width: 600, height: 400, crop: 'center' | image_tag: class: 'collections-card__image', loading: 'lazy' }}
          {%- else -%}
            <div class="collections-card__no-image">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
            </div>
          {%- endif -%}
        </div>
        <div class="collections-card__info">
          <h2 class="collections-card__title">{{ collection.title }}</h2>
          <span class="collections-card__count">{{ collection.products_count }} {{ 'collections.product_count' | t }}</span>
          {%- if collection.description != blank -%}
            <p class="collections-card__description">{{ collection.description | strip_html | truncatewords: 20 }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.collections-page {
  padding: 2rem 0;
}

.collections-page__title {
  font-family: var(--font-heading--family);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--color-foreground);
  margin: 0 0 2rem;
}

@media (min-width: 768px) {
  .collections-page__title {
    font-size: 2.4rem;
  }
}

.collections-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.25rem;
}

@media (min-width: 640px) {
  .collections-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .collections-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
}

.collections-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  border-radius: var(--style-border-radius-cards);
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.06);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}

.collections-card:hover {
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
}

.collections-card__image-wrap {
  aspect-ratio: 3 / 2;
  background: var(--color-background-secondary);
  overflow: hidden;
}

.collections-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.collections-card:hover .collections-card__image {
  transform: scale(1.03);
}

.collections-card__no-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #d1d5db;
}

.collections-card__info {
  padding: 1rem 1.25rem;
}

.collections-card__title {
  font-family: var(--font-heading--family);
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0;
  color: var(--color-foreground);
}

.collections-card__count {
  font-size: 0.75rem;
  color: #9ca3af;
  display: block;
  margin-top: 0.2rem;
}

.collections-card__description {
  font-size: 0.85rem;
  color: #6b7280;
  line-height: 1.5;
  margin: 0.5rem 0 0;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collections_grid",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

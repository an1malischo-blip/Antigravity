{% comment %}
  CH Distribution — Passwort-Seite (Shop gesperrt)
{% endcomment %}

<div class="password-page">
  <div class="password-page__card">
    {%- if settings.logo -%}
      <div class="password-page__logo">
        {{ settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
      </div>
    {%- else -%}
      <h2 class="password-page__shop-name">{{ shop.name }}</h2>
    {%- endif -%}

    <div class="password-page__icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    </div>

    <h1 class="password-page__title">{{ 'password.title' | t }}</h1>

    {%- if shop.password_message != blank -%}
      <p class="password-page__message">{{ shop.password_message }}</p>
    {%- endif -%}

    {%- form 'storefront_password' -%}
      {%- if form.errors -%}
        <div class="password-page__error">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="password-page__form">
        <div class="password-page__field">
          <label for="password-input" class="password-page__label">{{ 'password.password' | t }}</label>
          <input
            type="password"
            name="password"
            id="password-input"
            class="password-page__input"
            placeholder="{{ 'password.password' | t }}"
            autofocus
          >
        </div>
        <button type="submit" class="password-page__submit">
          {{ 'password.enter' | t }}
        </button>
      </div>
    {%- endform -%}
  </div>

  <p class="password-page__footer">
    &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
  </p>
</div>

{% stylesheet %}
.password-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100svh;
  padding: 2rem 1.5rem;
  background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
}

.password-page__card {
  background: var(--color-background);
  border-radius: var(--style-border-radius-cards);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
  padding: 2.5rem 2rem;
  width: 100%;
  max-width: 26rem;
  text-align: center;
}

.password-page__logo {
  margin-bottom: 1.5rem;
}

.password-page__logo img {
  max-height: 3rem;
  margin: 0 auto;
}

.password-page__shop-name {
  font-family: var(--font-heading--family);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-foreground);
  margin: 0 0 1.5rem;
}

.password-page__icon {
  color: var(--color-accent);
  margin-bottom: 1rem;
}

.password-page__title {
  font-family: var(--font-heading--family);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--color-foreground);
  margin: 0 0 0.5rem;
}

.password-page__message {
  font-size: 0.9rem;
  color: #6b7280;
  line-height: 1.5;
  margin: 0 0 1.5rem;
}

.password-page__error {
  background: #fef2f2;
  border: 1px solid #fca5a5;
  border-radius: var(--style-border-radius-inputs);
  padding: 0.6rem 0.75rem;
  margin-bottom: 1rem;
  font-size: 0.8rem;
  color: #dc2626;
}

.password-page__form {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.password-page__field {
  text-align: left;
}

.password-page__label {
  display: block;
  font-size: 0.8rem;
  font-weight: 600;
  margin-bottom: 0.3rem;
  color: var(--color-foreground);
}

.password-page__input {
  width: 100%;
  padding: 0.7rem 0.75rem;
  border: 2px solid #d1d5db;
  border-radius: var(--style-border-radius-inputs);
  font-size: 0.9rem;
  font-family: inherit;
  background: var(--color-background);
  color: var(--color-foreground);
  transition: border-color 0.15s ease;
}

.password-page__input:focus {
  outline: none;
  border-color: var(--color-accent);
}

.password-page__submit {
  width: 100%;
  padding: 0.75rem;
  background-color: var(--color-accent);
  color: var(--color-accent-text);
  border: 2px solid var(--color-accent);
  border-radius: var(--style-border-radius-buttons);
  font-size: 0.9rem;
  font-weight: 700;
  font-family: inherit;
  cursor: pointer;
  transition: background-color 0.2s ease;
}

.password-page__submit:hover {
  background-color: #162e78;
  border-color: #162e78;
}

.password-page__footer {
  margin-top: 2rem;
  font-size: 0.75rem;
  color: #9ca3af;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

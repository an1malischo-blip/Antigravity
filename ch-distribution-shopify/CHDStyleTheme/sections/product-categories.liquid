<div class="categories full-width">
  <div class="categories__inner">
    <div class="categories__header">
      {% if section.settings.eyebrow != blank %}
        <span class="categories__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="categories__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="categories__grid">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="categories__card"
          {{ block.shopify_attributes }}
        >
          <div class="categories__image">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 900, height: 600, crop: 'center' | image_tag: loading: 'lazy' }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
            <div class="categories__image-overlay"></div>
          </div>

          <div class="categories__content">
            {% if block.settings.eyebrow != blank %}
              <span class="categories__card-eyebrow">{{ block.settings.eyebrow }}</span>
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="categories__title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.description != blank %}
              <p class="categories__description">{{ block.settings.description }}</p>
            {% endif %}

            {% if block.settings.brands != blank %}
              <div class="categories__brands">
                {% assign brand_list = block.settings.brands | split: ',' %}
                {% for brand in brand_list %}
                  <span class="categories__brand-tag">{{ brand | strip }}</span>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .categories {
    background-color: var(--color-background-secondary);
    padding: 4rem var(--page-margin);
  }

  .categories__inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .categories__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .categories__eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .categories__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-foreground);
  }

  .categories__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .categories__card {
    display: block;
    text-decoration: none;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .categories__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
  }

  .categories__image {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background-color: var(--color-background-secondary);
  }

  .categories__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .categories__card:hover .categories__image img {
    transform: scale(1.05);
  }

  .categories__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .categories__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(0, 0, 0, 0.04) 100%);
  }

  .categories__content {
    padding: 1.5rem;
  }

  .categories__card-eyebrow {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .categories__title {
    font-family: var(--font-heading--family);
    font-size: 1.5rem;
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .categories__description {
    font-size: 0.85rem;
    line-height: 1.6;
    opacity: 0.65;
    margin-bottom: 1rem;
  }

  .categories__brands {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .categories__brand-tag {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.3rem 0.65rem;
    background-color: var(--color-background-secondary);
    border-radius: 2rem;
    color: var(--color-foreground);
    opacity: 0.7;
  }

  @media (min-width: 768px) {
    .categories {
      padding: 6rem var(--page-margin);
    }

    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .categories__heading {
      font-size: 2.75rem;
    }
  }

  @media (min-width: 1024px) {
    .categories__heading {
      font-size: 3.25rem;
    }

    .categories__content {
      padding: 1.75rem;
    }

    .categories__title {
      font-size: 1.75rem;
    }
  }
{% endstylesheet %}


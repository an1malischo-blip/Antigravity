<div class="featured-collections">
  {% if section.settings.heading != blank %}
    <h2 class="featured-collections__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="featured-collections__grid">
    {% for block in section.blocks %}
      {% assign collection = block.settings.collection %}
      <a
        href="{{ collection.url | default: '#' }}"
        class="featured-collections__card"
        {{ block.shopify_attributes }}
      >
        <div class="featured-collections__image">
          {% if collection.image %}
            {{ collection.image | image_url: width: 800, height: 600, crop: 'center' | image_tag: loading: 'lazy' }}
          {% elsif collection.products.first.featured_image %}
            {{ collection.products.first.featured_image | image_url: width: 800, height: 600, crop: 'center' | image_tag: loading: 'lazy' }}
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag }}
          {% endif %}
        </div>
        <div class="featured-collections__info">
          <h3 class="featured-collections__title">
            {{ collection.title | default: block.settings.custom_title | default: 'Collection' }}
          </h3>
          {% if collection.products_count %}
            <span class="featured-collections__count">
              {{ collection.products_count }} {{ 'sections.featured_collections.products' | t }}
            </span>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .featured-collections {
    padding: 3rem 0;
  }

  .featured-collections__heading {
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    text-align: center;
    color: var(--color-foreground);
  }

  .featured-collections__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .featured-collections__card {
    display: block;
    text-decoration: none;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .featured-collections__card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-2px);
  }

  .featured-collections__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--color-background-secondary);
  }

  .featured-collections__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .featured-collections__card:hover .featured-collections__image img {
    transform: scale(1.04);
  }

  .featured-collections__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-collections__info {
    padding: 1rem 1.25rem;
  }

  .featured-collections__title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .featured-collections__count {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.8rem;
    opacity: 0.6;
  }

  @media (min-width: 640px) {
    .featured-collections__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .featured-collections__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .featured-collections__heading {
      font-size: 1.75rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_collections.name",
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.featured_collections.blocks.collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.featured_collections.blocks.collection.settings.collection"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "t:sections.featured_collections.blocks.collection.settings.custom_title"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collections.settings.heading",
      "default": "Our collections"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collections.name",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}

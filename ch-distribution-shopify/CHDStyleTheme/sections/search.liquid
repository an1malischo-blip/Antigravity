{% comment %}
  CH Distribution — Suchseite
{% endcomment %}

<div class="search-page">
  <h1 class="search-page__title">{{ 'search.title' | t }}</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
    <div class="search-form__field">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
        class="search-form__input"
        autocomplete="off"
      >
      <button type="submit" class="search-form__btn" aria-label="{{ 'search.submit' | t }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
    </div>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <div class="search-empty">
        <p>{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      </div>
    {%- else -%}
      <p class="search-page__count">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

      {% paginate search.results by 20 %}
        <div class="search-grid">
          {%- for result in search.results -%}
            {%- assign featured_image = result.featured_image | default: result.image -%}
            <a href="{{ result.url }}" class="search-card">
              <div class="search-card__image-wrap">
                {%- if featured_image -%}
                  {{ featured_image | image_url: width: 300, height: 300, crop: 'center' | image_tag: class: 'search-card__image', loading: 'lazy' }}
                {%- else -%}
                  <div class="search-card__no-image">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                  </div>
                {%- endif -%}
              </div>
              <div class="search-card__info">
                <h3 class="search-card__title">{{ result.title }}</h3>
                {%- if result.price -%}
                  <span class="search-card__price">{{ result.price | money }}</span>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <div class="search-pagination">
            {{ paginate | default_pagination }}
          </div>
        {%- endif -%}
      {% endpaginate %}
    {%- endif -%}
  {%- endif -%}
</div>

{% stylesheet %}
.search-page {
  padding: 2rem 0;
}

.search-page__title {
  font-family: var(--font-heading--family);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--color-foreground);
  margin: 0 0 1.5rem;
  text-align: center;
}

/* Suchfeld */
.search-form {
  max-width: 36rem;
  margin: 0 auto 2rem;
}

.search-form__field {
  display: flex;
  border: 2px solid #d1d5db;
  border-radius: var(--style-border-radius-buttons);
  overflow: hidden;
  transition: border-color 0.15s ease;
}

.search-form__field:focus-within {
  border-color: var(--color-accent);
}

.search-form__input {
  flex: 1;
  padding: 0.85rem 1rem;
  border: none;
  font-size: 0.95rem;
  font-family: inherit;
  background: var(--color-background);
  color: var(--color-foreground);
  outline: none;
}

.search-form__btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 3.5rem;
  background: var(--color-accent);
  color: var(--color-accent-text);
  border: none;
  cursor: pointer;
  transition: background-color 0.15s ease;
}

.search-form__btn:hover {
  background-color: #162e78;
}

/* Ergebnisse */
.search-page__count {
  font-size: 0.85rem;
  color: #6b7280;
  margin-bottom: 1.5rem;
}

.search-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

@media (min-width: 640px) {
  .search-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 1024px) {
  .search-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
}

.search-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  border-radius: var(--style-border-radius-cards);
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.06);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}

.search-card:hover {
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
}

.search-card__image-wrap {
  aspect-ratio: 1 / 1;
  background: var(--color-background-secondary);
  overflow: hidden;
}

.search-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.search-card__no-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #d1d5db;
}

.search-card__info {
  padding: 0.75rem;
}

.search-card__title {
  font-size: 0.85rem;
  font-weight: 600;
  margin: 0;
  line-height: 1.35;
  color: var(--color-foreground);
}

.search-card__price {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--color-accent);
  margin-top: 0.25rem;
  display: block;
}

/* Keine Ergebnisse */
.search-empty {
  text-align: center;
  padding: 3rem 1rem;
  color: #6b7280;
  font-size: 0.95rem;
}

/* Pagination */
.search-pagination {
  display: flex;
  justify-content: center;
  padding: 2.5rem 0 1rem;
}

.search-pagination a,
.search-pagination span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2.25rem;
  height: 2.25rem;
  padding: 0 0.5rem;
  margin: 0 0.15rem;
  border-radius: var(--style-border-radius-buttons);
  font-size: 0.85rem;
  font-weight: 500;
  text-decoration: none;
  color: var(--color-foreground);
  transition: background-color 0.15s ease;
}

.search-pagination a:hover {
  background-color: var(--color-background-secondary);
}

.search-pagination span.current {
  background-color: var(--color-accent);
  color: var(--color-accent-text);
  font-weight: 700;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.search",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

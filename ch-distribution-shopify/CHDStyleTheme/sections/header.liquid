<header class="site-header">
  <div class="header__inner">

    {%- comment -%} LOGO oder Shop-Name {%- endcomment -%}
    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="header__logo-link" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          <img
            src="{{ section.settings.logo | image_url: width: 600 }}"
            alt="{{ shop.name }}"
            width="300"
            height="auto"
            loading="eager"
            class="header__logo-image"
          >
        {%- else -%}
          <img
            src="{{ 'logo.svg' | asset_url }}"
            alt="{{ shop.name }}"
            loading="eager"
            class="header__logo-image"
          >
        {%- endif -%}
      </a>
    </div>

    {%- comment -%} HAUPTNAVIGATION (Desktop) {%- endcomment -%}
    <nav class="header__nav" aria-label="Hauptnavigation">
      {%- for link in section.settings.menu.links -%}
        <a
          href="{{ link.url }}"
          class="header__nav-link{% if link.active %} is-active{% endif %}"
        >
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    {%- comment -%} RECHTE ICONS: Konto + Warenkorb + Burger {%- endcomment -%}
    <div class="header__actions">

      {%- if shop.customer_accounts_enabled -%}
        <shopify-account menu="{{ section.settings.customer_account_menu }}" class="header__action-btn" aria-label="Kundenkonto">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </shopify-account>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header__action-btn header__cart-btn" aria-label="Warenkorb">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>

      {%- comment -%} BURGER-BUTTON (nur Mobile) {%- endcomment -%}
      <button
        class="header__burger"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="burger-btn"
      >
        <span class="header__burger-bar"></span>
        <span class="header__burger-bar"></span>
        <span class="header__burger-bar"></span>
      </button>
    </div>

  </div>

  {%- comment -%} MOBILES MENÜ {%- endcomment -%}
  <nav class="header__mobile-menu" id="mobile-menu" aria-label="Mobiles Menü" aria-hidden="true">
    {%- for link in section.settings.menu.links -%}
      <a
        href="{{ link.url }}"
        class="header__mobile-link{% if link.active %} is-active{% endif %}"
      >
        {{ link.title }}
      </a>
    {%- endfor -%}
  </nav>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-background);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 5rem;
    padding: 0 var(--page-margin);
    max-width: var(--page-width);
    margin: 0 auto;
    gap: 1rem;
  }

  /* --- Logo --- */
  .header__logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .header__logo-image {
    height: auto;
    width: 12rem;
    max-height: 3.5rem;
    display: block;
    object-fit: contain;
  }

  .header__logo-text {
    font-family: var(--font-heading--family);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.01em;
  }

  /* --- Desktop-Navigation --- */
  .header__nav {
    display: none;
    align-items: center;
    gap: 0.125rem;
    flex: 1;
    justify-content: center;
  }

  .header__nav-link {
    padding: 0.5rem 0.875rem;
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    border-radius: var(--style-border-radius-buttons);
    transition: color 0.2s ease, background-color 0.2s ease;
    position: relative;
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0.25rem;
    left: 50%;
    transform: translateX(-50%) scaleX(0);
    width: 1.25rem;
    height: 1.5px;
    background-color: var(--color-accent);
    border-radius: 1px;
    transition: transform 0.25s ease;
  }

  .header__nav-link:hover {
    color: var(--color-accent);
  }

  .header__nav-link:hover::after,
  .header__nav-link.is-active::after {
    transform: translateX(-50%) scaleX(1);
  }

  .header__nav-link.is-active {
    color: var(--color-accent);
  }

  /* --- Aktions-Buttons --- */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header__action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--color-foreground);
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: none;
    background: none;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.2s ease, background-color 0.2s ease;
    position: relative;
  }

  .header__action-btn:hover {
    color: var(--color-accent);
    background-color: var(--color-background-secondary);
  }

  .header__action-btn svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .header__cart-count {
    position: absolute;
    top: 0.15rem;
    right: 0.15rem;
    background-color: var(--color-accent);
    color: var(--color-accent-text);
    font-size: 0.55rem;
    font-weight: 700;
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* --- Burger --- */
  .header__burger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.25rem;
    width: 2.5rem;
    height: 2.5rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    border-radius: 50%;
    transition: background-color 0.2s ease;
  }

  .header__burger:hover {
    background-color: var(--color-background-secondary);
  }

  .header__burger-bar {
    display: block;
    width: 1.125rem;
    height: 1.5px;
    background-color: var(--color-foreground);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .header__burger[aria-expanded="true"] .header__burger-bar:nth-child(1) {
    transform: translateY(0.375rem) rotate(45deg);
  }
  .header__burger[aria-expanded="true"] .header__burger-bar:nth-child(2) {
    opacity: 0;
  }
  .header__burger[aria-expanded="true"] .header__burger-bar:nth-child(3) {
    transform: translateY(-0.375rem) rotate(-45deg);
  }

  /* --- Mobiles Menü --- */
  .header__mobile-menu {
    display: flex;
    flex-direction: column;
    background-color: var(--color-background);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
  }

  .header__mobile-menu.is-open {
    max-height: 30rem;
  }

  .header__mobile-link {
    display: block;
    padding: 1rem var(--page-margin);
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    transition: color 0.2s ease, padding-left 0.2s ease;
  }

  .header__mobile-link:hover {
    color: var(--color-accent);
    padding-left: calc(var(--page-margin) + 0.5rem);
  }

  .header__mobile-link.is-active {
    color: var(--color-accent);
    font-weight: 600;
  }

  /* --- Desktop --- */
  @media (min-width: 768px) {
    .header__inner {
      height: 5.5rem;
    }

    .header__logo-image {
      width: 20rem;
      max-height: 4.5rem;
    }

    .header__nav {
      display: flex;
    }

    .header__burger {
      display: none;
    }

    .header__mobile-menu {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  const burgerBtn = document.getElementById('burger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (burgerBtn && mobileMenu) {
    burgerBtn.addEventListener('click', () => {
      const isOpen = burgerBtn.getAttribute('aria-expanded') === 'true';
      burgerBtn.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu.setAttribute('aria-hidden', String(isOpen));
      mobileMenu.classList.toggle('is-open', !isOpen);
    });
  }
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}

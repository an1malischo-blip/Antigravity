{% comment %}
  CH Distribution — Warenkorb (B2B)
{% endcomment %}

<div class="cart-page">
  <h1 class="cart-page__title">{{ 'cart.title' | t }}</h1>

  {%- if cart.item_count > 0 -%}
    <form action="{{ routes.cart_url }}" method="post" class="cart-form">

      {%- comment -%} Tabellen-Header (Desktop) {%- endcomment -%}
      <div class="cart-header">
        <span class="cart-header__product">{{ 'cart.product' | t }}</span>
        <span class="cart-header__price">{{ 'cart.price' | t }}</span>
        <span class="cart-header__quantity">{{ 'cart.quantity_label' | t }}</span>
        <span class="cart-header__total">{{ 'cart.total' | t }}</span>
      </div>

      {%- comment -%} Warenkorb-Artikel {%- endcomment -%}
      {%- for item in cart.items -%}
        <div class="cart-item">
          <div class="cart-item__product">
            <div class="cart-item__image">
              {%- if item.image -%}
                <a href="{{ item.url }}">
                  {{ item.image | image_url: width: 120, height: 120, crop: 'center' | image_tag: loading: 'lazy' }}
                </a>
              {%- endif -%}
            </div>

            <div class="cart-item__details">
              <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
              {%- if item.variant.title != 'Default Title' -%}
                <span class="cart-item__variant">{{ item.variant.title }}</span>
              {%- endif -%}
              {%- if item.sku != blank -%}
                <span class="cart-item__sku">{{ 'products.product.sku' | t }}: {{ item.sku }}</span>
              {%- endif -%}
              <span class="cart-item__price-mobile">{{ item.original_price | money }}</span>
            </div>
          </div>

          <div class="cart-item__price">
            {{ item.original_price | money }}
          </div>

          <div class="cart-item__quantity">
            <div class="cart-item__qty-control">
              <button type="button" class="cart-item__qty-btn" data-action="minus" data-index="{{ forloop.index }}" aria-label="{{ 'products.product.decrease_quantity' | t }}">−</button>
              <input
                type="number"
                name="updates[]"
                value="{{ item.quantity }}"
                min="0"
                class="cart-item__qty-input"
                aria-label="{{ 'cart.quantity_label' | t }}"
              >
              <button type="button" class="cart-item__qty-btn" data-action="plus" data-index="{{ forloop.index }}" aria-label="{{ 'products.product.increase_quantity' | t }}">+</button>
            </div>
            <a href="{{ item.url_to_remove }}" class="cart-item__remove">{{ 'cart.remove' | t }}</a>
          </div>

          <div class="cart-item__total">
            {{ item.final_line_price | money }}
          </div>
        </div>
      {%- endfor -%}

      {%- comment -%} Warenkorb-Footer {%- endcomment -%}
      <div class="cart-footer">
        <div class="cart-footer__note">
          <label for="cart-note" class="cart-footer__note-label">{{ 'cart.note' | t }}</label>
          <textarea id="cart-note" name="note" class="cart-footer__note-input" rows="3" placeholder="{{ 'cart.note_placeholder' | t }}">{{ cart.note }}</textarea>
        </div>

        <div class="cart-footer__summary">
          <div class="cart-footer__subtotal">
            <span>{{ 'cart.subtotal' | t }}</span>
            <span class="cart-footer__subtotal-price">{{ cart.total_price | money }}</span>
          </div>
          <p class="cart-footer__tax-note">{{ 'cart.tax_note' | t }}</p>

          <button type="submit" name="update" class="btn btn--secondary cart-footer__update">
            {{ 'cart.update' | t }}
          </button>
          <button type="submit" name="checkout" class="btn btn--primary cart-footer__checkout">
            {{ 'cart.checkout' | t }}
          </button>
        </div>
      </div>

    </form>

  {%- else -%}
    <div class="cart-empty">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      <p class="cart-empty__text">{{ 'cart.empty' | t }}</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ 'cart.continue_shopping' | t }}</a>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
.cart-page {
  padding: 2rem 0;
}

.cart-page__title {
  font-family: var(--font-heading--family);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--color-foreground);
  margin: 0 0 2rem;
}

@media (min-width: 768px) {
  .cart-page__title {
    font-size: 2.2rem;
  }
}

/* --- Header (Desktop) --- */
.cart-header {
  display: none;
}

@media (min-width: 768px) {
  .cart-header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 2px solid #e5e7eb;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6b7280;
  }

  .cart-header__price,
  .cart-header__quantity,
  .cart-header__total {
    text-align: center;
  }
}

/* --- Warenkorb-Artikel --- */
.cart-item {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
  padding: 1.25rem 0;
  border-bottom: 1px solid #e5e7eb;
  align-items: start;
}

@media (min-width: 768px) {
  .cart-item {
    grid-template-columns: 2fr 1fr 1fr 1fr;
    align-items: center;
  }
}

/* Produkt (Bild + Details) */
.cart-item__product {
  display: flex;
  gap: 1rem;
  align-items: start;
}

.cart-item__image {
  flex-shrink: 0;
}

.cart-item__image img {
  width: 5rem;
  height: 5rem;
  object-fit: cover;
  border-radius: var(--style-border-radius-cards);
  background: var(--color-background-secondary);
}

/* Details */
.cart-item__title {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--color-foreground);
  text-decoration: none;
  display: block;
  line-height: 1.3;
}

.cart-item__title:hover {
  color: var(--color-accent);
}

.cart-item__variant {
  font-size: 0.8rem;
  color: #6b7280;
  display: block;
  margin-top: 0.15rem;
}

.cart-item__sku {
  font-size: 0.75rem;
  color: #9ca3af;
  display: block;
  margin-top: 0.15rem;
}

.cart-item__price-mobile {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--color-foreground);
  margin-top: 0.25rem;
  display: block;
}

@media (min-width: 768px) {
  .cart-item__price-mobile {
    display: none;
  }
}

/* Preis (Desktop) */
.cart-item__price {
  display: none;
  font-size: 0.9rem;
  font-weight: 600;
  text-align: center;
}

@media (min-width: 768px) {
  .cart-item__price {
    display: block;
  }
}

/* Menge */
.cart-item__quantity {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.4rem;
}

@media (min-width: 768px) {
  .cart-item__quantity {
    align-items: center;
  }
}

.cart-item__qty-control {
  display: flex;
  align-items: center;
  border: 2px solid #d1d5db;
  border-radius: var(--style-border-radius-buttons);
  overflow: hidden;
}

.cart-item__qty-btn {
  width: 2.25rem;
  height: 2.25rem;
  background: var(--color-background-secondary);
  border: none;
  cursor: pointer;
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-foreground);
  transition: background-color 0.15s ease;
}

.cart-item__qty-btn:hover {
  background-color: var(--color-accent);
  color: var(--color-accent-text);
}

.cart-item__qty-input {
  width: 3rem;
  height: 2.25rem;
  text-align: center;
  border: none;
  border-left: 2px solid #d1d5db;
  border-right: 2px solid #d1d5db;
  font-size: 0.85rem;
  font-weight: 600;
  background: var(--color-background);
  color: var(--color-foreground);
  -moz-appearance: textfield;
}

.cart-item__qty-input::-webkit-outer-spin-button,
.cart-item__qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}

.cart-item__remove {
  font-size: 0.75rem;
  color: #9ca3af;
  text-decoration: underline;
  transition: color 0.15s ease;
}

.cart-item__remove:hover {
  color: #dc2626;
}

/* Total */
.cart-item__total {
  display: none;
  font-size: 0.95rem;
  font-weight: 700;
  text-align: center;
  color: var(--color-foreground);
}

@media (min-width: 768px) {
  .cart-item__total {
    display: block;
  }
}

/* --- Footer / Zusammenfassung --- */
.cart-footer {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding-top: 1.5rem;
}

@media (min-width: 768px) {
  .cart-footer {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
  }
}

.cart-footer__note {
  flex: 1;
  max-width: 28rem;
}

.cart-footer__note-label {
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: block;
  margin-bottom: 0.5rem;
}

.cart-footer__note-input {
  width: 100%;
  border: 2px solid #d1d5db;
  border-radius: var(--style-border-radius-cards);
  padding: 0.75rem;
  font-size: 0.85rem;
  font-family: inherit;
  resize: vertical;
  background: var(--color-background);
  color: var(--color-foreground);
}

.cart-footer__note-input:focus {
  outline: none;
  border-color: var(--color-accent);
}

.cart-footer__summary {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  min-width: 18rem;
}

.cart-footer__subtotal {
  display: flex;
  justify-content: space-between;
  font-size: 1.1rem;
  font-weight: 700;
}

.cart-footer__subtotal-price {
  color: var(--color-accent);
  font-size: 1.25rem;
}

.cart-footer__tax-note {
  font-size: 0.78rem;
  color: #9ca3af;
  margin: 0;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0.85rem 2rem;
  border-radius: var(--style-border-radius-buttons);
  font-size: 0.9rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  border: 2px solid transparent;
  cursor: pointer;
  transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  font-family: inherit;
  text-decoration: none;
  width: 100%;
  min-height: 3rem;
}

.btn--primary {
  background-color: var(--color-accent);
  color: var(--color-accent-text);
  border-color: var(--color-accent);
}

.btn--primary:hover {
  background-color: #162e78;
  border-color: #162e78;
}

.btn--secondary {
  background-color: transparent;
  color: var(--color-foreground);
  border-color: #d1d5db;
}

.btn--secondary:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
}

.cart-footer__update {
  font-size: 0.8rem;
  padding: 0.6rem 1rem;
  min-height: 2.5rem;
}

/* --- Leerer Warenkorb --- */
.cart-empty {
  text-align: center;
  padding: 4rem 1rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.25rem;
}

.cart-empty svg {
  color: #d1d5db;
}

.cart-empty__text {
  font-size: 1rem;
  color: #6b7280;
  margin: 0;
}

.cart-empty .btn {
  width: auto;
}
{% endstylesheet %}

{% javascript %}
  document.querySelectorAll('.cart-item__qty-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var input = btn.closest('.cart-item__qty-control').querySelector('.cart-item__qty-input');
      var val = parseInt(input.value, 10);
      if (btn.dataset.action === 'minus' && val > 0) {
        input.value = val - 1;
      } else if (btn.dataset.action === 'plus') {
        input.value = val + 1;
      }
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}

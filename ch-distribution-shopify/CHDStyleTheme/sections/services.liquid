<div class="services full-width">
  <div class="services__inner">
    <div class="services__header">
      {% if section.settings.eyebrow != blank %}
        <span class="services__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="services__heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>

    <div class="services__grid">
      {% for block in section.blocks %}
        <div class="services__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="services__icon">
              {{ block.settings.icon | image_url: width: 80 | image_tag }}
            </div>
          {% else %}
            <div class="services__icon services__icon--placeholder">
              <span class="services__icon-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="services__title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="services__description">{{ block.settings.description }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .services {
    background-color: var(--color-background);
    padding: 4rem var(--page-margin);
  }

  .services__inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .services__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .services__eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .services__heading {
    font-family: var(--font-heading--family);
    font-style: var(--font-heading--style);
    font-size: 2rem;
    font-weight: 400;
    line-height: 1.15;
    color: var(--color-foreground);
  }

  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .services__card {
    background-color: var(--color-background-secondary);
    border-radius: var(--style-border-radius-cards);
    padding: 2rem 1.5rem;
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .services__card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .services__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .services__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .services__icon--placeholder {
    background-color: var(--color-accent);
    border-radius: 0.5rem;
    color: var(--color-accent-text);
  }

  .services__icon-number {
    font-family: var(--font-heading--family);
    font-size: 1.1rem;
    font-weight: 600;
  }

  .services__title {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .services__description {
    font-size: 0.85rem;
    line-height: 1.65;
    color: var(--color-foreground);
    opacity: 0.65;
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .services {
      padding: 6rem var(--page-margin);
    }

    .services__heading {
      font-size: 2.75rem;
    }
  }

  @media (min-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .services__heading {
      font-size: 3.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.services.name",
  "blocks": [
    {
      "type": "service",
      "name": "t:sections.services.blocks.service.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:sections.services.blocks.service.settings.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.services.blocks.service.settings.title",
          "default": "Service"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.services.blocks.service.settings.description",
          "default": "Short description of this service."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.services.settings.eyebrow",
      "default": "What we offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.services.settings.heading",
      "default": "Our services"
    }
  ],
  "presets": [
    {
      "name": "t:sections.services.name",
      "blocks": [
        { "type": "service", "settings": { "title": "B2B wholesale", "description": "Competitive wholesale pricing for retailers, kiosks, and online shops across Europe." } },
        { "type": "service", "settings": { "title": "Fast shipping", "description": "Reliable delivery within 48 hours across Germany and Europe-wide within 5 business days." } },
        { "type": "service", "settings": { "title": "Brand portfolio", "description": "Curated selection of trending international snacks, sweets, and vape products." } },
        { "type": "service", "settings": { "title": "Personal support", "description": "Dedicated account manager for individual consulting and custom orders." } },
        { "type": "service", "settings": { "title": "Flexible orders", "description": "Low minimum order quantities and mixed pallets tailored to your needs." } },
        { "type": "service", "settings": { "title": "Quality assurance", "description": "All products meet EU standards with full traceability and proper documentation." } }
      ]
    }
  ]
}
{% endschema %}

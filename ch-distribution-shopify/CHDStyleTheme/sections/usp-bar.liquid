<div class="usp-bar full-width">
  <div class="usp-bar__inner">
    {% for block in section.blocks %}
      <div class="usp-bar__item" {{ block.shopify_attributes }}>
        {% if block.settings.icon != blank %}
          <div class="usp-bar__icon">
            {{ block.settings.icon | image_url: width: 80 | image_tag }}
          </div>
        {% endif %}
        {% if block.settings.title != blank %}
          <h3 class="usp-bar__title">{{ block.settings.title }}</h3>
        {% endif %}
        {% if block.settings.description != blank %}
          <p class="usp-bar__description">{{ block.settings.description }}</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .usp-bar {
    background-color: var(--color-background-secondary);
    padding: 2.5rem var(--page-margin);
  }

  .usp-bar__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .usp-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding: 1rem;
  }

  .usp-bar__icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.25rem;
  }

  .usp-bar__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .usp-bar__title {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-foreground);
  }

  .usp-bar__description {
    font-size: 0.85rem;
    color: var(--color-foreground);
    opacity: 0.7;
    line-height: 1.5;
    max-width: 28ch;
  }

  @media (min-width: 768px) {
    .usp-bar__inner {
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.usp_bar.name",
  "blocks": [
    {
      "type": "usp_item",
      "name": "t:sections.usp_bar.blocks.item.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:sections.usp_bar.blocks.item.settings.icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.usp_bar.blocks.item.settings.title",
          "default": "Benefit"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:sections.usp_bar.blocks.item.settings.description",
          "default": "Short description of this benefit."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.usp_bar.name",
      "blocks": [
        {
          "type": "usp_item",
          "settings": {
            "title": "Fast shipping",
            "description": "Quick and reliable delivery."
          }
        },
        {
          "type": "usp_item",
          "settings": {
            "title": "Premium quality",
            "description": "Only the best products."
          }
        },
        {
          "type": "usp_item",
          "settings": {
            "title": "Personal service",
            "description": "Your dedicated contact person."
          }
        }
      ]
    }
  ]
}
{% endschema %}

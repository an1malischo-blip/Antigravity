{% comment %}
  CH Distribution — Collection-Seite (B2B)
  Zeigt alle Produkte einer Kollektion als professionelles Produktraster.
{% endcomment %}

<div class="collection-page">

  {%- comment -%} Collection Header {%- endcomment -%}
  <div class="collection-header">
    <div class="collection-header__text">
      <h1 class="collection-header__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p class="collection-header__description">{{ collection.description }}</p>
      {%- endif -%}
    </div>
    <span class="collection-header__count">
      {{ collection.products_count }} {{ 'collections.product_count' | t }}
    </span>
  </div>

  {%- comment -%} Produktraster {%- endcomment -%}
  {% paginate collection.products by 24 %}
    {%- if collection.products.size > 0 -%}
      <div class="collection-grid">
        {%- for product in collection.products -%}
          {%- assign current_variant = product.selected_or_first_available_variant -%}
          <a href="{{ product.url }}" class="product-card">

            {%- comment -%} Produktbild {%- endcomment -%}
            <div class="product-card__image-wrap">
              {%- if product.featured_image -%}
                {{ product.featured_image | image_url: width: 400, height: 400, crop: 'center' | image_tag: class: 'product-card__image', loading: 'lazy' }}
              {%- else -%}
                <div class="product-card__no-image">
                  <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
              {%- endif -%}

              {%- comment -%} Sale-Badge {%- endcomment -%}
              {%- if current_variant.compare_at_price > current_variant.price -%}
                <span class="product-card__badge">{{ 'products.product.sale' | t }}</span>
              {%- endif -%}

              {%- comment -%} Verfügbarkeits-Indikator {%- endcomment -%}
              {%- unless product.available -%}
                <span class="product-card__badge product-card__badge--sold-out">{{ 'products.product.sold_out' | t }}</span>
              {%- endunless -%}
            </div>

            {%- comment -%} Produktinfos {%- endcomment -%}
            <div class="product-card__info">
              {%- if product.vendor != blank -%}
                <span class="product-card__vendor">{{ product.vendor }}</span>
              {%- endif -%}

              <h3 class="product-card__title">{{ product.title }}</h3>

              {%- if current_variant.sku != blank -%}
                <span class="product-card__sku">{{ 'products.product.sku' | t }}: {{ current_variant.sku }}</span>
              {%- endif -%}

              <div class="product-card__pricing">
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  <span class="product-card__price product-card__price--sale">{{ current_variant.price | money }}</span>
                  <span class="product-card__price-original">{{ current_variant.compare_at_price | money }}</span>
                {%- else -%}
                  <span class="product-card__price">{{ current_variant.price | money }}</span>
                {%- endif -%}
                <span class="product-card__tax">{{ 'products.product.tax_note' | t }}</span>
              </div>

              {%- comment -%} Verfügbarkeit {%- endcomment -%}
              <div class="product-card__stock">
                {%- if product.available -%}
                  <span class="product-card__stock-dot product-card__stock-dot--in"></span>
                  <span>{{ 'products.product.in_stock' | t }}</span>
                {%- else -%}
                  <span class="product-card__stock-dot product-card__stock-dot--out"></span>
                  <span>{{ 'products.product.sold_out' | t }}</span>
                {%- endif -%}
              </div>
            </div>

          </a>
        {%- endfor -%}
      </div>

      {%- comment -%} Pagination {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <div class="collection-pagination">
          {{ paginate | default_pagination }}
        </div>
      {%- endif -%}

    {%- else -%}
      <div class="collection-empty">
        <p>{{ 'collections.empty' | t }}</p>
      </div>
    {%- endif -%}
  {% endpaginate %}

</div>

{% stylesheet %}
/* ====================================================
   CH DISTRIBUTION — COLLECTION-SEITE (B2B)
==================================================== */

.collection-page {
  padding: 2rem 0;
}

/* --- Collection Header --- */
.collection-header {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid #e5e7eb;
}

@media (min-width: 768px) {
  .collection-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
  }
}

.collection-header__title {
  font-family: var(--font-heading--family);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--color-foreground);
  margin: 0;
  line-height: 1.2;
}

@media (min-width: 768px) {
  .collection-header__title {
    font-size: 2.4rem;
  }
}

.collection-header__description {
  font-size: 0.9rem;
  line-height: 1.6;
  color: #6b7280;
  margin: 0.5rem 0 0;
  max-width: 40rem;
}

.collection-header__count {
  font-size: 0.8rem;
  color: #9ca3af;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

/* --- Produktraster --- */
.collection-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
}

@media (min-width: 640px) {
  .collection-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
}

@media (min-width: 1024px) {
  .collection-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
}

/* --- Produktkarte --- */
.product-card {
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  border-radius: var(--style-border-radius-cards);
  overflow: hidden;
  background: var(--color-background);
  border: 1px solid rgba(0, 0, 0, 0.06);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}

.product-card:hover {
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  transform: translateY(-2px);
}

/* Bild */
.product-card__image-wrap {
  position: relative;
  aspect-ratio: 1 / 1;
  background-color: var(--color-background-secondary);
  overflow: hidden;
}

.product-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.product-card:hover .product-card__image {
  transform: scale(1.03);
}

.product-card__no-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  color: #d1d5db;
}

/* Badges */
.product-card__badge {
  position: absolute;
  top: 0.5rem;
  left: 0.5rem;
  background-color: #dc2626;
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.product-card__badge--sold-out {
  background-color: #6b7280;
}

/* Info-Bereich */
.product-card__info {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 0.875rem;
}

.product-card__vendor {
  font-size: 0.7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-accent);
}

.product-card__title {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-foreground);
  margin: 0;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-card__sku {
  font-size: 0.7rem;
  color: #9ca3af;
}

/* Preis */
.product-card__pricing {
  display: flex;
  align-items: baseline;
  gap: 0.4rem;
  flex-wrap: wrap;
  margin-top: 0.25rem;
}

.product-card__price {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-foreground);
}

.product-card__price--sale {
  color: #dc2626;
}

.product-card__price-original {
  font-size: 0.8rem;
  color: #9ca3af;
  text-decoration: line-through;
}

.product-card__tax {
  font-size: 0.65rem;
  color: #9ca3af;
  width: 100%;
}

/* Verfügbarkeit */
.product-card__stock {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.7rem;
  font-weight: 600;
  margin-top: 0.25rem;
}

.product-card__stock-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.product-card__stock-dot--in {
  background-color: #22c55e;
}

.product-card__stock-dot--out {
  background-color: #ef4444;
}

/* --- Pagination --- */
.collection-pagination {
  display: flex;
  justify-content: center;
  padding: 2.5rem 0 1rem;
}

.collection-pagination a,
.collection-pagination span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 2.25rem;
  height: 2.25rem;
  padding: 0 0.5rem;
  margin: 0 0.15rem;
  border-radius: var(--style-border-radius-buttons);
  font-size: 0.85rem;
  font-weight: 500;
  text-decoration: none;
  color: var(--color-foreground);
  transition: background-color 0.15s ease, color 0.15s ease;
}

.collection-pagination a:hover {
  background-color: var(--color-background-secondary);
}

.collection-pagination span.current {
  background-color: var(--color-accent);
  color: var(--color-accent-text);
  font-weight: 700;
}

/* --- Leer-Zustand --- */
.collection-empty {
  text-align: center;
  padding: 4rem 1rem;
  color: #9ca3af;
  font-size: 0.95rem;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
